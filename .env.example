# --- Umumiy ---
TIMEZONE=Asia/Tashkent
# PRODUCTION'da false bo'lsin! DEBUG=false bo'lsa placeholder sirlar bilan API
# ishga tushmaydi (xavfsizlik qo'riqchisi) va dev-login o'chadi.
DEBUG=true

# --- Bot ---
BOT_TOKEN=
# Faqat cPanel (shared hosting) deploy uchun: bot alohida polling jarayoni emas,
# shu API ichida webhook orqali ishlaydi. Docker/VPS'da FALSE qoldiring (bot
# alohida polling qiladi). Batafsil: DEPLOY-CPANEL.md
BOT_WEBHOOK_ENABLED=false

# --- Ma'lumotlar bazasi ---
# SQLite — mavjud app.db faylini serverga yuklaysiz (ma'lumotlar bilan). Yo'l
# ilova ildiziga nisbatan (./app.db = ~/hodimlar-tizimi/app.db).
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Docker (VPS) uchun PostgreSQL misoli — compose POSTGRES_PASSWORD bilan o'rnatadi:
# DATABASE_URL=postgresql+asyncpg://hodimlar:PAROL@db:5432/hodimlar
POSTGRES_PASSWORD=hodimlar

# --- API ---
# PRODUCTION: har ikkala sirni tasodifiy qiymat bilan almashtiring, masalan:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=please-change-this-secret
JWT_EXPIRE_MINUTES=1440
BOT_SHARED_SECRET=please-change-this-bot-secret
# Production'da sayt domeni (CORS uchun), masalan https://hodimlar.example.uz
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# --- Sayt (Telegram Login) ---
TELEGRAM_LOGIN_BOT_USERNAME=

# --- Guruhlar (2-bosqich) ---
# Asosiy guruh — mobilograf videolari va issiq lid xabarlari shu yerga tushadi.
# Chat ID odatda manfiy son (masalan -1001234567890). Bilish uchun botni guruhga
# qo'shing va @userinfobot yoki botning update logidan foydalaning.
TELEGRAM_GROUP_CHAT_ID=
# Qo'shimcha statistika guruh(lar)i (ixtiyoriy). Kunlik/haftalik digest DOIM asosiy
# guruhga chiqadi; bu yerga yozilgan guruh(lar)ga ham HAM yuboriladi (nusxa). Bir
# nechta guruh bo'lsa vergul bilan ajrating: -100111,-100222. Bo'sh — faqat asosiy guruh.
TELEGRAM_STATS_GROUP_CHAT_ID=

# --- CRM (3-bosqich) ---
# none | amocrm | onec | uysot — "none" bo'lsa CRM sinxronizatsiyasi o'tkazib yuboriladi,
# kunlik natijalar faqat qo'lda (sayt orqali) kiritiladi.
CRM_TYPE=none
# amoCRM uchun: uzoq muddatli (long-lived) kirish tokeni.
# Uysot uchun: Open API tokeni (X-Open-Api-Token) — "Call History: Read" va "Lead: Read" ruxsatlari bilan.
CRM_API_KEY=
# amoCRM subdomeni, masalan "mycompany" (https://mycompany.amocrm.ru). Uysot uchun kerak emas.
CRM_AMOCRM_SUBDOMAIN=
# /crm/webhook endpointini himoya qilish uchun maxfiy kalit
CRM_WEBHOOK_SECRET=
# Uysot uchun: "tashrif" deb hisoblanadigan pipeline bosqichining ID'si.
# GET /v1/open-api/pipe/all (X-Open-Api-Token bilan) chaqirib, kerakli bosqichning
# "id" qiymatini shu yerga qo'ying (masalan "Tashrif" nomli bosqich).
CRM_UYSOT_VISIT_PIPE_STATUS_ID=
# Operator AI sabab tekshiruvi: "hali ishlanmagan (ochiq/yangi)" deb hisoblanadigan
# bosqich ID'lari, vergul bilan (masalan "101,102" — "Yangi lid", "Aloqa kutilmoqda").
# Operator "lid/baza tugadi" desa, shu bosqichlarda unga biriktirilgan lidlar CRM'dan
# sanaladi: 0 ta bo'lsa sabab tasdiqlanadi, bor bo'lsa rahbarga ogohlantirish ketadi.
# Bo'sh qoldirilsa bu tekshiruv o'chiq (sabab baribir yoziladi, hukmsiz).
CRM_UYSOT_OPEN_LEAD_PIPE_STATUS_IDS=
# Soatlik reja AVTOMATIK eslatmasi (bot har soatda xodimlarga xabar yuboradi).
# Default o'chiq — haqiqiy xodimlarga xabar ketgani sabab. Ishga tushirishga
# tayyor bo'lganda true qo'ying. Botdagi "📋 Bugungi rejam" tugmasi bundan
# qat'i nazar ishlayveradi (xodimning o'zi ochadi).
HOURLY_PLAN_ENABLED=false

# --- Operator AI (avto-reja + AI murabbiy) ---
# Default o'chiq: o'chiq bo'lsa avto-reja endpointlari no-op, AI matnlari
# deterministik shablon bilan yoziladi (tashqi API chaqirilmaydi).
AI_ENABLED=false
# Matn yozadigan provayder: anthropic (Claude, tavsiya) | gemini (bepul tier).
# Hisob-qarorlar har doim kodda — provayder faqat matn sifatiga ta'sir qiladi.
# OPERATOR_ prefiksi ataylab: umumiy AI_PROVIDER/GEMINI_API_KEY nomlarini boshqa
# vositalar (ollama va h.k.) global env'da band qilgan bo'lishi mumkin.
OPERATOR_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
OPERATOR_GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Nudge PUSH (soatlik kuzatuvda orqada qolgan operatorlarga Telegram xabar).
# AI_ENABLED'dan alohida opt-in — haqiqiy xodimlarga xabar ketadi. Sinov uchun
# POST /ai-watch/tick?dry_run=true (yubormasdan matnlarni qaytaradi).
AI_NUDGE_ENABLED=false
