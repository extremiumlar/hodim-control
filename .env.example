# --- Umumiy ---
TIMEZONE=Asia/Tashkent
DEBUG=true

# --- Bot ---
BOT_TOKEN=

# --- Ma'lumotlar bazasi ---
# Lokal sinov (Docker'siz): SQLite
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Docker/production (PostgreSQL) misoli:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/hodimlar

# --- API ---
JWT_SECRET=please-change-this-secret
JWT_EXPIRE_MINUTES=1440
BOT_SHARED_SECRET=please-change-this-bot-secret
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# --- Sayt (Telegram Login) ---
TELEGRAM_LOGIN_BOT_USERNAME=

# --- Mobilograf + kunlik xulosa guruhi (2-bosqich) ---
# Bot qo'shilgan guruhning chat ID'si (odatda manfiy son, masalan -1001234567890).
# Bilish uchun botni guruhga qo'shing va @userinfobot yoki botning update logidan foydalaning.
TELEGRAM_GROUP_CHAT_ID=

# --- CRM (3-bosqich) ---
# none | amocrm | onec | uysot — "none" bo'lsa CRM sinxronizatsiyasi o'tkazib yuboriladi,
# kunlik natijalar faqat qo'lda (sayt orqali) kiritiladi.
CRM_TYPE=none
# amoCRM uchun: uzoq muddatli (long-lived) kirish tokeni.
# Uysot uchun: Open API tokeni (X-Open-Api-Token) — "Call History: Read" ruxsati bilan.
CRM_API_KEY=
# amoCRM subdomeni, masalan "mycompany" (https://mycompany.amocrm.ru). Uysot uchun kerak emas.
CRM_AMOCRM_SUBDOMAIN=
# /crm/webhook endpointini himoya qilish uchun maxfiy kalit
CRM_WEBHOOK_SECRET=
# Uysot uchun: "tashrif" deb hisoblanadigan pipeline bosqichining ID'si.
# GET /v1/open-api/pipe/all (X-Open-Api-Token bilan) chaqirib, kerakli bosqichning
# "id" qiymatini shu yerga qo'ying (masalan "Tashrif" nomli bosqich).
CRM_UYSOT_VISIT_PIPE_STATUS_ID=
# Soatlik reja AVTOMATIK eslatmasi (bot har soatda xodimlarga xabar yuboradi).
# Default o'chiq — haqiqiy xodimlarga xabar ketgani sabab. Ishga tushirishga
# tayyor bo'lganda true qo'ying. Botdagi "📋 Bugungi rejam" tugmasi bundan
# qat'i nazar ishlayveradi (xodimning o'zi ochadi).
HOURLY_PLAN_ENABLED=false
