*.db
*.sqlite3
logs

# Sirlar (compose env_file orqali beriladi, image ichiga kirmasin)
.env

# Frontend artefaktlari (image ichida qayta build qilinadi)
web/node_modules
web/dist

# Iste'foga chiqqan Django backend — deploy qilinmaydi (arxiv)
verifix
