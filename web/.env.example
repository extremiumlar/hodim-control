# /api — vite dev proxy (vite.config.ts) yoki nginx orqali FastAPI:8000 ga boradi.
# To'g'ridan-to'g'ri manzil (masalan http://localhost:8000) faqat shu kompyuterda
# ishlaydi — telefonda "localhost" telefonning o'zi bo'lib qoladi.
VITE_API_BASE_URL=/api
VITE_DEBUG=true
VITE_TELEGRAM_LOGIN_BOT_USERNAME=
